<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>TBA Cycle Time Analysis</title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    th { cursor: pointer; }
  </style>
</head>
<body>
  <h1>TBA Cycle Time Analysis - <%= new Date().getFullYear() %> Season</h1>

  <div class="week-links">
    <strong>Filter by Week:</strong>
    <a href="/">All</a>
    <% weeks.forEach(week => { %>
      <a href="/week/<%= week %>">Week <%= week + 1 %></a>
    <% }); %>
  </div>

  <h2>Season Summary</h2>
  <table class="summary-table">
    <thead>
      <tr>
        <th>Metric</th>
        <th>Min</th>
        <th>Avg</th>
        <th>Max</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>Cycle Time</td>
        <td>
          <%= (seasonStats.cycle.min.value / 60).toFixed(2) %>m
          <% if (seasonStats.cycle.min.context) { %>
            <br>(<%= seasonStats.cycle.min.context.event.name %> - Match <%= seasonStats.cycle.min.context.match.match_number %>)
          <% } %>
        </td>
        <td><%= (seasonStats.cycle.avg / 60).toFixed(2) %>m</td>
        <td>
          <%= (seasonStats.cycle.max.value / 60).toFixed(2) %>m
          <% if (seasonStats.cycle.max.context) { %>
            <br>(<%= seasonStats.cycle.max.context.event.name %> - Match <%= seasonStats.cycle.max.context.match.match_number %>)
          <% } %>
        </td>
      </tr>
      <tr>
        <td>Referee Time</td>
        <td>
          <%= (seasonStats.ref.min.value / 60).toFixed(2) %>m
          <% if (seasonStats.ref.min.context) { %>
            <br>(<%= seasonStats.ref.min.context.event.name %> - Match <%= seasonStats.ref.min.context.match.match_number %>)
          <% } %>
        </td>
        <td><%= (seasonStats.ref.avg / 60).toFixed(2) %>m</td>
        <td>
          <%= (seasonStats.ref.max.value / 60).toFixed(2) %>m
          <% if (seasonStats.ref.max.context) { %>
            <br>(<%= seasonStats.ref.max.context.event.name %> - Match <%= seasonStats.ref.max.context.match.match_number %>)
          <% } %>
        </td>
      </tr>
      <tr>
        <td>Schedule Difference</td>
        <td>
          <%= (seasonStats.schedule.min.value / 60).toFixed(2) %>m
          <% if (seasonStats.schedule.min.context) { %>
            <br>(<%= seasonStats.schedule.min.context.event.name %> - Match <%= seasonStats.schedule.min.context.match.match_number %>)
          <% } %>
        </td>
        <td><%= (seasonStats.schedule.avg / 60).toFixed(2) %>m</td>
        <td>
          <%= (seasonStats.schedule.max.value / 60).toFixed(2) %>m
          <% if (seasonStats.schedule.max.context) { %>
            <br>(<%= seasonStats.schedule.max.context.event.name %> - Match <%= seasonStats.schedule.max.context.match.match_number %>)
          <% } %>
        </td>
      </tr>
    </tbody>
  </table>

  <h2>Event Cycle Time Distribution</h2>
  <div class="chart-container">
    <canvas id="cycleTimeHistogram"></canvas>
  </div>

  <h2>Eligible Events</h2>
  <table class="events-table" id="eventsTable">
    <thead>
      <tr>
        <th onclick="sortTable(0)">Event Name</th>
        <th onclick="sortTable(1)">Avg Cycle Time (min)</th>
        <th onclick="sortTable(2)">Avg Referee Time (min)</th>
        <th onclick="sortTable(3)">Avg Schedule Diff (min)</th>
        <th onclick="sortTable(4)">Daily Total Schedule Delta (min)</th>
      </tr>
    </thead>
    <tbody>
      <% events.forEach(event => { %>
        <tr>
          <td><a href="/event/<%= event.key %>"><%= event.name %></a></td>
          <td><%= (event.avgCycleTime / 60).toFixed(2) %></td>
          <td><%= (event.avgRefTime / 60).toFixed(2) %></td>
          <td><%= (event.avgScheduleDiff / 60).toFixed(2) %></td>
          <td><%= (event.dailyTotalScheduleDelta / 60).toFixed(2) %></td>
        </tr>
      <% }); %>
    </tbody>
  </table>

  <script>
    // Base font size for Chart.js
    Chart.defaults.font.size = 12; // Default size, will be scaled

    // Table sorting function
    function sortTable(n) {
      var table, rows, switching, i, x, y, shouldSwitch, dir, switchcount = 0;
      table = document.getElementById("eventsTable");
      switching = true;
      dir = "asc";
      while (switching) {
        switching = false;
        rows = table.rows;
        for (i = 1; i < (rows.length - 1); i++) {
          shouldSwitch = false;
          x = rows[i].getElementsByTagName("TD")[n];
          y = rows[i + 1].getElementsByTagName("TD")[n];

          let xVal = x.innerText.toLowerCase();
          let yVal = y.innerText.toLowerCase();

          if (!isNaN(parseFloat(xVal)) && !isNaN(parseFloat(yVal))) {
              xVal = parseFloat(xVal);
              yVal = parseFloat(yVal);
          }

          if (dir == "asc") {
            if (xVal > yVal) {
              shouldSwitch = true;
              break;
            }
          } else if (dir == "desc") {
            if (xVal < yVal) {
              shouldSwitch = true;
              break;
            }
          }
        }
        if (shouldSwitch) {
          rows[i].parentNode.insertBefore(rows[i + 1], rows[i]);
          switching = true;
          switchcount ++;
        } else {
          if (switchcount == 0 && dir == "asc") {
            dir = "desc";
            switching = true;
          }
        }
      }
    }

    // Histogram generation
    function generateHistogram() {
        const events = <%- JSON.stringify(events) %>;
        const cycleTimesInMinutes = events.map(event => event.avgCycleTime / 60);

        const buckets = {};
        cycleTimesInMinutes.forEach(time => {
            const bucket = Math.floor(time);
            if (!buckets[bucket]) {
                buckets[bucket] = 0;
            }
            buckets[bucket]++;
        });

        const sortedBuckets = Object.keys(buckets).sort((a, b) => parseInt(a) - parseInt(b));

        const labels = sortedBuckets.map(bucket => `${bucket}-${parseInt(bucket) + 1} min`);
        const data = sortedBuckets.map(bucket => buckets[bucket]);

        new Chart(document.getElementById('cycleTimeHistogram').getContext('2d'), {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    label: '# of Events',
                    data: data,
                    backgroundColor: 'rgba(75, 192, 192, 0.6)',
                    borderColor: 'rgba(75, 192, 192, 1)',
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                  title: {
                    display: true,
                    text: 'Event Cycle Time Distribution',
                    font: {
                      size: Chart.defaults.font.size * 2 // 100% increase for headers
                    }
                  }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        title: {
                            display: true,
                            text: 'Number of Events',
                            font: {
                              size: Chart.defaults.font.size * 1.5 // 50% increase for axis labels
                            }
                        },
                        ticks: {
                          font: {
                            size: Chart.defaults.font.size * 1.5 // 50% increase for axis ticks
                          }
                        }
                    },
                    x: {
                        title: {
                            display: true,
                            text: 'Average Cycle Time',
                            font: {
                              size: Chart.defaults.font.size * 1.5 // 50% increase for axis labels
                            }
                        },
                        ticks: {
                          font: {
                            size: Chart.defaults.font.size * 1.5 // 50% increase for axis ticks
                          }
                        }
                    }
                }
            }
        });
    }

    window.onload = function() {
        sortTable(0);
        generateHistogram();
    };
  </script>
</body>
</html>
