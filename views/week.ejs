<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>TBA Cycle Time Analysis - Week <%= weekNumber + 1 %></title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    th { cursor: pointer; }
  </style>
</head>
<body>
  <h1>TBA Cycle Time Analysis - <%= new Date().getFullYear() %> Season - Week <%= weekNumber + 1 %></h1>

  <h2>Week <%= weekNumber + 1 %> Summary</h2>
  <table class="summary-table">
    <thead>
      <tr>
        <th>Metric</th>
        <th>Min</th>
        <th>Avg</th>
        <th>Max</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>Cycle Time</td>
        <td>
          <%= (weekStats.cycle.min.value / 60).toFixed(2) %>m
          <% if (weekStats.cycle.min.context) { %>
            <br>(<%= weekStats.cycle.min.context.event.name %> - Match <%= weekStats.cycle.min.context.match.match_number %>)
          <% } %>
        </td>
        <td><%= (weekStats.cycle.avg / 60).toFixed(2) %>m</td>
        <td>
          <%= (weekStats.cycle.max.value / 60).toFixed(2) %>m
          <% if (weekStats.cycle.max.context) { %>
            <br>(<%= weekStats.cycle.max.context.event.name %> - Match <%= weekStats.cycle.max.context.match.match_number %>)
          <% } %>
        </td>
      </tr>
      <tr>
        <td>Referee Time</td>
        <td>
          <%= (weekStats.ref.min.value / 60).toFixed(2) %>m
          <% if (weekStats.ref.min.context) { %>
            <br>(<%= weekStats.ref.min.context.event.name %> - Match <%= weekStats.ref.min.context.match.match_number %>)
          <% } %>
        </td>
        <td><%= (weekStats.ref.avg / 60).toFixed(2) %>m</td>
        <td>
          <%= (weekStats.ref.max.value / 60).toFixed(2) %>m
          <% if (weekStats.ref.max.context) { %>
            <br>(<%= weekStats.ref.max.context.event.name %> - Match <%= weekStats.ref.max.context.match.match_number %>)
          <% } %>
        </td>
      </tr>
      <tr>
        <td>Schedule Difference</td>
        <td>
          <%= (weekStats.schedule.min.value / 60).toFixed(2) %>m
          <% if (weekStats.schedule.min.context) { %>
            <br>(<%= weekStats.schedule.min.context.event.name %> - Match <%= weekStats.schedule.min.context.match.match_number %>)
          <% } %>
        </td>
        <td><%= (weekStats.schedule.avg / 60).toFixed(2) %>m</td>
        <td>
          <%= (weekStats.schedule.max.value / 60).toFixed(2) %>m
          <% if (weekStats.schedule.max.context) { %>
            <br>(<%= weekStats.schedule.max.context.event.name %> - Match <%= weekStats.schedule.max.context.match.match_number %>)
          <% } %>
        </td>
      </tr>
    </tbody>
  </table>

  <h2>Eligible Events for Week <%= weekNumber + 1 %></h2>
  <table class="events-table" id="eventsTable">
    <thead>
      <tr>
        <th onclick="sortTable(0)">Event Name</th>
        <th onclick="sortTable(1)">Avg Cycle Time (min)</th>
        <th onclick="sortTable(2)">Avg Referee Time (min)</th>
        <th onclick="sortTable(3)">Avg Schedule Diff (min)</th>
        <th onclick="sortTable(4)">Daily Total Schedule Delta (min)</th>
      </tr>
    </thead>
    <tbody>
      <% events.forEach(event => { %>
        <tr>
          <td><a href="/event/<%= event.key %>"><%= event.name %></a></td>
          <td><%= (event.avgCycleTime / 60).toFixed(2) %></td>
          <td><%= (event.avgRefTime / 60).toFixed(2) %></td>
          <td><%= (event.avgScheduleDiff / 60).toFixed(2) %></td>
          <td><%= (event.dailyTotalScheduleDelta / 60).toFixed(2) %></td>
        </tr>
      <% }); %>
    </tbody>
  </table>

  <script>
    function sortTable(n) {
      var table, rows, switching, i, x, y, shouldSwitch, dir, switchcount = 0;
      table = document.getElementById("eventsTable");
      switching = true;
      dir = "asc";
      while (switching) {
        switching = false;
        rows = table.rows;
        for (i = 1; i < (rows.length - 1); i++) {
          shouldSwitch = false;
          x = rows[i].getElementsByTagName("TD")[n];
          y = rows[i + 1].getElementsByTagName("TD")[n];

          let xVal = x.innerText.toLowerCase();
          let yVal = y.innerText.toLowerCase();

          if (!isNaN(parseFloat(xVal)) && !isNaN(parseFloat(yVal))) {
              xVal = parseFloat(xVal);
              yVal = parseFloat(yVal);
          }

          if (dir == "asc") {
            if (xVal > yVal) {
              shouldSwitch = true;
              break;
            }
          } else if (dir == "desc") {
            if (xVal < yVal) {
              shouldSwitch = true;
              break;
            }
          }
        }
        if (shouldSwitch) {
          rows[i].parentNode.insertBefore(rows[i + 1], rows[i]);
          switching = true;
          switchcount ++;
        } else {
          if (switchcount == 0 && dir == "asc") {
            dir = "desc";
            switching = true;
          }
        }
      }
    }

    window.onload = function() {
        sortTable(0);
    };
  </script>
</body>
</html>
